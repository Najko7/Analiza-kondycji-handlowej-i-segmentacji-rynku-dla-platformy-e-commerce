        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "from scipy import stats\n",
        "from google.cloud import bigquery\n",
        "from google.colab import auth\n",
        "\n",
        "# Uwierzytelnienie użytkownika\n",
        "auth.authenticate_user()\n",
        "\n",
        "# Inicjalizacja klienta BigQuery\n",
        "client = bigquery.Client(project='data-analytics-mate')\n",
        "\n",
        "query = \"\"\"\n",
        "SELECT\n",
        "    s.date AS order_date,                             -- data zamówienia\n",
        "    s.ga_session_id AS session_id,                    -- identyfikator sesji\n",
        "    sp.continent AS continent,                        -- kontynent\n",
        "    sp.country AS country,                            -- kraj\n",
        "    sp.device AS device,                              -- urządzenie\n",
        "    sp.browser AS browser,                            -- przeglądarka\n",
        "    sp.mobile_model_name AS device_model_name,        -- nazwa modelu urządzenia\n",
        "    sp.operating_system AS operating_system,          -- system operacyjny\n",
        "    sp.language AS browser_language,                  -- język przeglądarki\n",
        "    sp.name AS traffic_source_information,            -- informacje o źródle ruchu\n",
        "    sp.channel AS traffic_channel,                    -- kanał ruchu\n",
        "    acc_s.account_id AS registered_user_id,           -- identyfikator zarejestrowanego użytkownika\n",
        "\n",
        "    -- Konwersja flag 0/1 na postać logiczną (True/False). Jeśli brak konta, dajemy False.\n",
        "    CASE WHEN a.is_verified = 1 THEN TRUE ELSE FALSE END AS is_email_confirmed,\n",
        "    CASE WHEN a.is_unsubscribed = 0 AND a.id IS NOT NULL THEN TRUE ELSE FALSE END AS is_newsletter_subscriber,\n",
        "\n",
        "    p.category AS product_category,                   -- kategoria produktu\n",
        "    p.name AS product_name,                           -- nazwa produktu\n",
        "    p.price AS price,                                 -- cena\n",
        "    p.short_description AS short_product_description  -- krótki opis produktu\n",
        "\n",
        "FROM `data-analytics-mate.DA.session` s\n",
        "\n",
        "-- Dołączamy parametry sesji\n",
        "LEFT JOIN `data-analytics-mate.DA.session_params` sp\n",
        "    ON s.ga_session_id = sp.ga_session_id\n",
        "\n",
        "-- Dołączamy zamówienia z danej sesji (sesja może mieć wiele zamówionych produktów)\n",
        "LEFT JOIN `data-analytics-mate.DA.order` o\n",
        "    ON s.ga_session_id = o.ga_session_id\n",
        "\n",
        "-- Dołączamy szczegóły produktu na podstawie ID produktu z zamówienia\n",
        "LEFT JOIN `data-analytics-mate.DA.product` p\n",
        "    ON o.item_id = p.item_id\n",
        "\n",
        "-- Łączymy sesję z tabelą pośredniczącą kont\n",
        "LEFT JOIN `data-analytics-mate.DA.account_session` acc_s\n",
        "    ON s.ga_session_id = acc_s.ga_session_id\n",
        "\n",
        "-- Pobieramy szczegóły konta subskrybenta\n",
        "LEFT JOIN `data-analytics-mate.DA.account` a\n",
        "    ON acc_s.account_id = a.id\n",
        "\"\"\"\n",
        "\n",
        "# Pobranie danych do DataFrame\n",
        "df = client.query(query).to_dataframe()\n",
        "\n",
        "df.to_csv('ecommerce_portfolio_data.csv', index=False)"
      ]
